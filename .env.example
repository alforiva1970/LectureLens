# University Integration Config
# Get these from your University IT department or Moodle settings
UNIVERSITY_OAUTH_CLIENT_ID=
UNIVERSITY_OAUTH_CLIENT_SECRET=
UNIVERSITY_OAUTH_AUTH_URL=https://shibboleth.polimi.it/idp/profile/SAML2/Redirect/SSO
UNIVERSITY_OAUTH_TOKEN_URL=
UNIVERSITY_API_BASE_URL=https://moodle.polimi.it/webservice/rest/server.php

# Gemini API Key (already handled by the platform)
GEMINI_API_KEY=

# Firebase Client Configuration (Secured by Secret Management)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend URL for split architecture (e.g., https://lecture-lens-backend.up.railway.app)
# Leave empty for local development or AI Studio preview
VITE_BACKEND_URL=

# Monetization
VITE_BUY_ME_A_COFFEE_USERNAME=
